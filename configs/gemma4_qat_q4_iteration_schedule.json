[
  {
    "iteration": 1,
    "name": "sampler baseline with temp-1 safety caps",
    "enable": ["enforce_sampler", "cap_max_tokens_by_task"],
    "set": {
      "max_tokens_default_cap": 256,
      "max_tokens_json_cap": 512,
      "max_tokens_tool_cap": 192,
      "max_tokens_instruction_cap": 192,
      "max_tokens_reasonmath_cap": 512,
      "max_tokens_coding_cap": 512
    }
  },
  {
    "iteration": 2,
    "name": "strip model residue and extract code",
    "enable": ["strip_reasoning", "strip_markdown_fences", "extract_python_code"]
  },
  {
    "iteration": 3,
    "name": "extract fenced and embedded JSON",
    "enable": ["repair_json"]
  },
  {
    "iteration": 4,
    "name": "handle escaped and double-encoded JSON",
    "enable": ["parse_escaped_json"]
  },
  {
    "iteration": 5,
    "name": "coerce extraction numeric strings",
    "enable": ["coerce_numeric_json_values"]
  },
  {
    "iteration": 6,
    "name": "parse tagged tool calls",
    "enable": ["parse_tagged_tool_calls"]
  },
  {
    "iteration": 7,
    "name": "parse JSON tool-call payloads",
    "enable": ["parse_json_tool_calls"]
  },
  {
    "iteration": 8,
    "name": "parse function-call syntax",
    "enable": ["parse_function_syntax"]
  },
  {
    "iteration": 9,
    "name": "normalize tool arguments to schemas",
    "enable": ["normalize_tool_args"]
  },
  {
    "iteration": 10,
    "name": "dedupe batch calls",
    "enable": ["dedupe_tool_calls"]
  },
  {
    "iteration": 11,
    "name": "guard direct-answer tasks",
    "enable": ["direct_answer_guard"]
  },
  {
    "iteration": 12,
    "name": "synthesize obvious missing calls",
    "enable": ["synthesize_obvious_tool_calls"]
  },
  {
    "iteration": 13,
    "name": "complete obvious missing batch calls",
    "enable": ["synthesize_missing_batch_calls"]
  },
  {
    "iteration": 14,
    "name": "canonicalize answer lines",
    "enable": ["canonicalize_reasonmath_answer_line"]
  },
  {
    "iteration": 15,
    "name": "retry empty responses",
    "enable": ["retry_empty"],
    "set": {"max_retries": 1}
  },
  {
    "iteration": 16,
    "name": "retry malformed extraction JSON",
    "enable": ["retry_malformed_json"],
    "set": {"max_retries": 1}
  },
  {
    "iteration": 17,
    "name": "full optimized profile",
    "enable": [
      "enforce_sampler",
      "strip_reasoning",
      "strip_markdown_fences",
      "extract_python_code",
      "repair_json",
      "coerce_numeric_json_values",
      "parse_tagged_tool_calls",
      "parse_json_tool_calls",
      "parse_function_syntax",
      "parse_escaped_json",
      "normalize_tool_args",
      "dedupe_tool_calls",
      "direct_answer_guard",
      "synthesize_obvious_tool_calls",
      "synthesize_missing_batch_calls",
      "canonicalize_reasonmath_answer_line",
      "retry_empty",
      "retry_malformed_json"
    ],
    "set": {"max_retries": 1}
  }
]
