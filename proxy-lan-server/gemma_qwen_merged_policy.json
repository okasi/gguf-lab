{
  "name": "gemma-qwen-merged",
  "version": "family-sampler-v18-fraction-small-major-json-scalars",
  "temperature": 1,
  "top_p": 0.95,
  "top_k": 64,
  "min_p": 0,
  "enforce_sampler": true,
  "respect_client_sampler": true,
  "default_sampler_profile": "gemma4",
  "sampler_profiles": {
    "gemma4": {
      "model_patterns": [
        "gemma",
        "gemma-4",
        "gemma4"
      ],
      "temperature": 1,
      "top_p": 0.95,
      "top_k": 64,
      "min_p": 0
    },
    "qwen": {
      "model_patterns": [
        "qwen",
        "qwopus"
      ],
      "temperature": 0.85,
      "top_p": 0.95,
      "top_k": 20,
      "min_p": 0
    }
  },
  "strip_reasoning": true,
  "strip_markdown_fences": true,
  "extract_python_code": true,
  "extract_javascript_code": true,
  "repair_json": true,
  "parse_tagged_tool_calls": true,
  "parse_json_tool_calls": true,
  "parse_function_syntax": true,
  "parse_escaped_json": true,
  "normalize_tool_args": true,
  "dedupe_tool_calls": true,
  "passthrough_response": true,
  "repair_json_on_passthrough": true,
  "repair_schema_json_on_passthrough": true,
  "coerce_untyped_json_scalars": true,
  "untyped_json_scalar_options": {
    "coerce_plus_numbers": true,
    "coerce_per_unit_numbers": true,
    "coerce_unicode_unit_numbers": true,
    "coerce_fraction_leading_numbers": true,
    "preserve_id_like_integers": true,
    "preserve_time_suffix_numbers": true,
    "preserve_small_major_decimals": true
  },
  "retry_empty": true,
  "retry_malformed_json": true,
  "retry_malformed_python": true,
  "retry_malformed_javascript": true,
  "retry_missing_tool_call": true,
  "max_retries": 0,
  "metadata": {
    "purpose": "Shared Gemma 4 and Qwen/Qwopus protocol adaptation with family-specific sampler defaults.",
    "sampler_policy": "Keep family samplers pinned unless a sampler sweep is explicitly requested.",
    "target_clients": [
      "BenchLoop",
      "OpenClaw/ClawBench",
      "Hermes Agent",
      "opencode",
      "OpenAI-compatible local agent clients"
    ],
    "audit_note": "Protocol adaptation only; never infer answers or actions from prompts, task names, or expected outputs."
  }
}
