{
  "name": "gemma4-q4-iteration",
  "version": "iter-01",
  "temperature": 1.0,
  "top_p": 0.95,
  "top_k": 64,
  "enforce_sampler": true,
  "strip_reasoning": false,
  "strip_markdown_fences": false,
  "repair_json": false,
  "coerce_numeric_json_values": false,
  "parse_tagged_tool_calls": false,
  "parse_json_tool_calls": false,
  "parse_function_syntax": false,
  "parse_escaped_json": false,
  "normalize_tool_args": false,
  "dedupe_tool_calls": false,
  "direct_answer_guard": false,
  "synthesize_obvious_tool_calls": false,
  "synthesize_missing_batch_calls": false,
  "canonicalize_reasonmath_answer_line": false,
  "retry_empty": false,
  "retry_malformed_json": false,
  "retry_missing_tool_call": false,
  "max_retries": 0,
  "cap_max_tokens_by_task": true,
  "max_tokens_default_cap": 512,
  "max_tokens_json_cap": 768,
  "max_tokens_tool_cap": 256,
  "max_tokens_instruction_cap": 256,
  "max_tokens_reasonmath_cap": 768,
  "max_tokens_coding_cap": 768,
  "metadata": {
    "iteration": 1,
    "enabled_features": [
      "enforce_sampler",
      "cap_max_tokens_by_task"
    ],
    "schedule_item": {
      "iteration": 1,
      "name": "sampler baseline with temp-1 safety caps",
      "enable": [
        "enforce_sampler",
        "cap_max_tokens_by_task"
      ],
      "set": {
        "max_tokens_default_cap": 512,
        "max_tokens_json_cap": 768,
        "max_tokens_tool_cap": 256,
        "max_tokens_instruction_cap": 256,
        "max_tokens_reasonmath_cap": 768,
        "max_tokens_coding_cap": 768
      }
    }
  }
}